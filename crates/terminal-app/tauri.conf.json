{
  "$schema": "https://raw.githubusercontent.com/nicktomlin/tauri/refs/heads/v2/crates/tauri-cli/schema.json",
  "productName": "Terminal",
  "version": "0.1.0",
  "identifier": "com.terminal.engine",
  "build": {
    "frontendDist": "../../frontend/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": { "script": "npm run dev", "cwd": "../../frontend" },
    "beforeBuildCommand": { "script": "npm run build", "cwd": "../../frontend" }
  },
  "app": {
    "windows": [
      {
        "title": "Terminal",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "withGlobalTauri": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
